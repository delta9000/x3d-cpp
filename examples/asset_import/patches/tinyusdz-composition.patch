+      PUSH_WARN(fmt::format("Failed to open mtlx asset `{}`; skipping.",
+                            asset_path));
+      if (dst_primspec_root) {
+        (*dst_primspec_root) = nullptr;
+      }
+      return true;
     }
 
     ps.name() = "MaterialX";
