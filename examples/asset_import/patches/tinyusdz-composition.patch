+    // asset's prims would be dropped. The resolver's cwd/search paths are
+    // already set to this asset's base dir (above), so relative subLayer paths
+    // resolve correctly.
+    if (!layer.metas().subLayers.empty()) {
+      Layer composited_sublayers;
+      if (CompositeSublayers(resolver, layer, &composited_sublayers, &_warn,
+                             &_err)) {
+        layer = std::move(composited_sublayers);
+      } else {
