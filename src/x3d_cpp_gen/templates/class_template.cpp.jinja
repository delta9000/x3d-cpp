namespace factory_detail {
std::shared_ptr<X3DNode> create{{ class_name }}() {
    return std::make_shared<{{ class_name }}>();
}
} // namespace factory_detail

{% endif %}
{% if namespace %}
} // namespace {{ namespace }}
