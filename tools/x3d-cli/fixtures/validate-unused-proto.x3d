<?xml version="1.0" encoding="UTF-8"?>
<X3D profile="Interchange" version="4.0" xmlns:xsd="http://www.w3.org/2001/XMLSchema-instance">
  <head>
    <meta name="title" content="validate-unused-proto.x3d"/>
  </head>
  <Scene>
    <ProtoDeclare name="MyShape">
      <ProtoInterface>
        <field accessType="initializeOnly" type="SFColor" name="color" value="1 0 0"/>
      </ProtoInterface>
      <ProtoBody>
        <Shape>
          <Appearance>
            <Material diffuseColor="1 0 0"/>
          </Appearance>
          <Box/>
        </Shape>
      </ProtoBody>
    </ProtoDeclare>
    <!-- No ProtoInstance of MyShape — this should trigger the check -->
    <Shape>
      <Box/>
    </Shape>
  </Scene>
</X3D>
