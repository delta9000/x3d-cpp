<?xml version="1.0" encoding="UTF-8"?>
<X3D profile="Interchange" version="4.0" xmlns:xsd="http://www.w3.org/2001/XMLSchema-instance">
  <head>
    <meta name="title" content="validate-ifs-no-coordindex.x3d"/>
  </head>
  <Scene>
    <Shape>
      <Appearance>
        <Material diffuseColor="0 0.5 1"/>
      </Appearance>
      <!-- IndexedFaceSet has a Coordinate (with data) but no coordIndex -->
      <IndexedFaceSet>
        <Coordinate point="0 0 0 1 0 0 0 1 0"/>
      </IndexedFaceSet>
    </Shape>
  </Scene>
</X3D>
