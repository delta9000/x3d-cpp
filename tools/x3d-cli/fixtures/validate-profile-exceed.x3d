<?xml version="1.0" encoding="UTF-8"?>
<!-- Fixture: validate-profile-exceed.x3d
     Declares profile="Interchange" but uses TouchSensor (PointingDeviceSensor
     component, level 1) which is NOT part of the Interchange profile.
     Expected: x3d validate exits 3, profile-fit reports >= Interactive/Immersive,
     and a profile-exceed diagnostic mentioning TouchSensor. -->
<X3D profile="Interchange" version="4.0" xmlns:xsd="http://www.w3.org/2001/XMLSchema-instance">
  <head>
    <meta name="title" content="validate-profile-exceed.x3d"/>
    <meta name="description" content="Fixture: TouchSensor exceeds declared Interchange profile."/>
  </head>
  <Scene>
    <Shape>
      <Appearance>
        <Material diffuseColor="0 0.5 1"/>
      </Appearance>
      <Box size="1 1 1"/>
    </Shape>
    <TouchSensor DEF="TS" description="click me"/>
  </Scene>
</X3D>
