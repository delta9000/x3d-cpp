<?xml version="1.0" encoding="UTF-8"?>
<X3D profile="Interchange" version="4.0" xmlns:xsd="http://www.w3.org/2001/XMLSchema-instance">
  <head>
    <meta name="title" content="validate-ils-no-coordindex.x3d"/>
  </head>
  <Scene>
    <Shape>
      <Appearance>
        <Material emissiveColor="1 0 0"/>
      </Appearance>
      <!-- IndexedLineSet has a Coordinate but no coordIndex -->
      <IndexedLineSet>
        <Coordinate point="0 0 0 1 0 0 1 1 0"/>
      </IndexedLineSet>
    </Shape>
  </Scene>
</X3D>
